{
    "name":  "clipkeep",
    "private":  true,
    "version":  "0.1.0",
    "scripts":  {
                    "dev":  "next dev",
                    "build":  "node --max-old-space-size=4096 ./node_modules/next/dist/bin/next build",
                    "cf:build":  "opennextjs-cloudflare build",
                    "start":  "next start",
                    "lint":  "next lint",
                    "typecheck":  "tsc --noEmit",
                    "d1:migrate:local":  "wrangler d1 migrations apply clipkeep-db --local",
                    "d1:migrate:remote":  "wrangler d1 migrations apply clipkeep-db --remote",
                    "cf:deploy":  "npm run cf:build \u0026\u0026 wrangler deploy",
                    "deploy":  "npm run cf:deploy",
                    "build:verbose":  "next build"
                },
    "dependencies":  {
                         "next":  "15.2.9",
                         "react":  "19.0.0",
                         "react-dom":  "19.0.0"
                     },
    "devDependencies":  {
                            "@opennextjs/cloudflare":  "^1.17.1",
                            "@types/node":  "22.10.1",
                            "@types/react":  "19.0.2",
                            "@types/react-dom":  "19.0.2",
                            "eslint":  "9.19.0",
                            "eslint-config-next":  "15.2.9",
                            "typescript":  "5.7.2",
                            "wrangler":  "4.34.0"
                        }
}